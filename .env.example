# ─────────────────────────────────────────────────────────────
# CIOS Platform — Environment Variables
# Copy this to .env.local for local dev, and paste each into
# Netlify → Site settings → Environment variables for production.
# ─────────────────────────────────────────────────────────────

# ─── Required: app URL ─────────────────────────────────────
# In production, set to your actual Netlify URL (no trailing slash).
NEXT_PUBLIC_APP_URL=https://your-site.netlify.app

# ─── Required: Clerk (auth) ────────────────────────────────
# Get from clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Optional — for the /api/webhooks/clerk endpoint (sign-in event tracking)
CLERK_WEBHOOK_SECRET=whsec_xxx
# Routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/post-auth
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/post-auth

# ─── Required: Supabase (database) ─────────────────────────
# Get from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# Preferred current key names
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
# Legacy fallback keys (optional while migrating)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Local migration access only. Do not add these to NEXT_PUBLIC_* variables and
# do not commit real values. The access token comes from Supabase Account Tokens;
# the database password is from Project Settings -> Database.
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_DB_PASSWORD=replace-with-project-database-password

# ─── Required for messaging realtime: Ably ─────────────────
# Get from ably.com → Apps → API keys
NEXT_PUBLIC_ABLY_API_KEY=xxx:xxx

# ─── Required for image / file uploads: Cloudinary ─────────
# Get from cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-preset

# ─── Required for cron jobs (digest emails) ────────────────
# Any random long string — protects /api/cron/* from public hits
CRON_SECRET=replace-with-a-long-random-string

# ─── Optional: Web push notifications ──────────────────────
# Generate with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Optional: Sentry (error monitoring) ───────────────────
# Get from sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
NEXT_PUBLIC_SENTRY_PROJECT_URL=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Optional: Display app version in header ───────────────
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── Flutterwave (server-side hosted checkout) ─────────────
FLW_SECRET_KEY=
FLW_SECRET_HASH=
# Optional; reserved for future client-side Flutterwave components.
NEXT_PUBLIC_FLW_PUBLIC_KEY=
OPERATIONS_ALERT_WEBHOOK_URL=

# ─── Optional: Upstash Redis (caching) ─────────────────────
# HUGE Vercel-credit saver — caches sidebar badges, engagement settings,
# leaderboards, and course context. Without this, every page load hits
# Supabase 5–8 times.
# Sign up at upstash.com (free 10k commands/day), create a Redis DB,
# copy the REST URL + token from the "REST API" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Cloudflare R2 (file storage) ────────────────
# Stores certificate PDFs (and future user uploads) on R2 instead of
# regenerating them or eating Vercel bandwidth. R2 has free 10 GB
# storage AND unlimited egress (zero bandwidth charges).
# Setup:
#   1. cloudflare.com → R2 → Create bucket (e.g. "cios-files")
#   2. R2 → Manage R2 API Tokens → Create token (Object Read & Write)
#   3. Account ID is on the R2 dashboard's right sidebar
#   4. Optional: connect a custom domain to the bucket and set
#      R2_PUBLIC_BASE_URL (otherwise we use short-lived presigned URLs).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cios-files
R2_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────
# NOT SET HERE — managed inside the Super Admin UI:
#   • Email provider (Resend / SendGrid / SMTP) — set at /super-admin/email-settings
#   • AI provider (OpenAI / Claude / Gemini / etc.) — set at /super-admin/ai-settings
# These are stored in the `app_settings` table, encrypted at rest via Supabase.
# ─────────────────────────────────────────────────────────────
