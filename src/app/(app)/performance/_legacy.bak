        <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 16 }}>
          <span style={{ fontSize: 18 }}>💡</span>
          <h3 style={{ fontSize: 16, fontWeight: 700, color: "#E8EDF5" }}>Improvement Suggestions</h3>
        </div>
        <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
          {[
            { icon: "🎯", title: "Boost Community Engagement", desc: "Participate in at least 3 community discussions per week to raise your Community score above 75%." },
            { icon: "⚡", title: "Complete Learning Modules Faster", desc: "You have 4 overdue learning modules. Finishing them this week will push Learning to 80%+." },
