"use client";
/* eslint-disable @next/next/no-img-element */

const metrics = [
  { label: "Attendance", value: 92, color: "#66BB6A" },
  { label: "Tasks", value: 85, color: "#1E88E5" },
  { label: "Learning", value: 70, color: "#FFC107" },
  { label: "Community", value: 65, color: "#AB47BC" },
  { label: "Reporting", value: 80, color: "#FF7043" },
];

const monthlyTrend = [
  { month: "Nov", value: 62 },
  { month: "Dec", value: 68 },
  { month: "Jan", value: 71 },
  { month: "Feb", value: 74 },
  { month: "Mar", value: 76 },
  { month: "Apr", value: 78 },
];

function ScoreRing({ value, size, color, label, sublabel }: { value: number; size: number; color: string; label?: string; sublabel?: string }) {
  const sw = 8;
  const r = (size - sw) / 2;
  const circ = 2 * Math.PI * r;
  const offset = circ - (value / 100) * circ;
  return (
    <div style={{ position: "relative", width: size, height: size, display: "flex", alignItems: "center", justifyContent: "center" }}>
      <svg width={size} height={size} style={{ transform: "rotate(-90deg)", position: "absolute" }}>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="rgba(255,255,255,0.06)" strokeWidth={sw} />
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={color} strokeWidth={sw} strokeLinecap="round" strokeDasharray={circ} strokeDashoffset={offset} style={{ transition: "stroke-dashoffset 1s ease", filter: `drop-shadow(0 0 8px ${color}44)` }} />
      </svg>
      <div style={{ position: "relative", zIndex: 1, textAlign: "center" }}>
        <div style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: size * 0.22, fontWeight: 800, color }}>{value}%</div>
        {label && <div style={{ fontSize: 12, color: "#8892A4", marginTop: 2 }}>{label}</div>}
      </div>
    </div>
  );
}

export default function PerformancePage() {
  const card = { background: "#111827", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 16, padding: 24 };

  return (
    <div>
      {/* Header */}
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
        <h1 style={{ fontSize: 24, fontWeight: 800, color: "#E8EDF5", fontFamily: "'Space Grotesk', sans-serif" }}>Performance Analytics</h1>
        <span style={{ fontSize: 13, color: "#5A6478" }}>Last updated: April 10, 2026</span>
      </div>

      {/* 3 cards row */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 16, marginBottom: 24 }}>
        {/* Overall Score */}
        <div style={{ ...card, textAlign: "center", display: "flex", flexDirection: "column", alignItems: "center", gap: 12 }}>
          <h3 style={{ fontSize: 16, fontWeight: 700, color: "#E8EDF5", marginBottom: 8 }}>Overall Score</h3>
          <ScoreRing value={78} size={180} color="#1E88E5" />
          <div style={{ marginTop: 8 }}>
            <span style={{ fontFamily: "'Space Grotesk', sans-serif", fontSize: 28, fontWeight: 800, color: "#1E88E5" }}>B+</span>
            <span style={{ fontSize: 14, color: "#8892A4", marginLeft: 8 }}>Grade</span>
          </div>
          <div style={{ fontSize: 13, color: "#66BB6A", display: "flex", alignItems: "center", gap: 4 }}>
            ↗ +4% from last month
          </div>
        </div>

        {/* Score Breakdown */}
        <div style={card}>
          <h3 style={{ fontSize: 16, fontWeight: 700, color: "#E8EDF5", marginBottom: 16 }}>Score Breakdown</h3>
          <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
            {metrics.map(m => (
              <div key={m.label}>
                <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6 }}>
                  <span style={{ fontSize: 13, color: "#E8EDF5" }}>{m.label}</span>
                  <span style={{ fontSize: 13, fontWeight: 700, color: m.color }}>{m.value}%</span>
                </div>
                <div style={{ height: 6, background: "rgba(255,255,255,0.06)", borderRadius: 3, overflow: "hidden" }}>
                  <div style={{ height: "100%", width: `${m.value}%`, background: m.color, borderRadius: 3, transition: "width 0.8s ease" }} />
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Promotion Readiness */}
        <div style={{ ...card, textAlign: "center", display: "flex", flexDirection: "column", alignItems: "center", gap: 8 }}>
          <h3 style={{ fontSize: 16, fontWeight: 700, color: "#E8EDF5", marginBottom: 8 }}>Promotion Readiness</h3>
          <ScoreRing value={72} size={160} color="#1E88E5" />
          <div style={{ marginTop: 8 }}>
            <div style={{ fontSize: 15, fontWeight: 700, color: "#1E88E5" }}>Senior Intern → Team Lead</div>
            <div style={{ fontSize: 12, color: "#8892A4", marginTop: 2 }}>Top 15% of interns</div>
          </div>
          <div style={{ fontSize: 12, color: "#8892A4", marginTop: 8, lineHeight: 1.6 }}>
            Complete 3 more leadership tasks and maintain 80%+ for 2 months to qualify.
          </div>
        </div>
      </div>

      {/* Monthly Trend */}
      <div style={{ ...card, marginBottom: 24 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 20 }}>
          <span style={{ fontSize: 18 }}>📈</span>
          <h3 style={{ fontSize: 16, fontWeight: 700, color: "#E8EDF5" }}>Monthly Trend</h3>
        </div>
        <div style={{ display: "flex", alignItems: "flex-end", gap: 12, height: 160 }}>
          {monthlyTrend.map((m, i) => {
            const isLast = i === monthlyTrend.length - 1;
            return (
              <div key={m.month} style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", gap: 6, height: "100%" }}>
                <span style={{ fontSize: 11, fontWeight: 700, color: isLast ? "#66BB6A" : "#8892A4" }}>{m.value}%</span>
                <div style={{ flex: 1, width: "100%", display: "flex", alignItems: "flex-end" }}>
                  <div style={{
                    width: "100%", height: `${m.value}%`,
                    background: isLast
                      ? "linear-gradient(180deg, #66BB6A, #1E88E5)"
                      : "linear-gradient(180deg, #1E88E5, #1565C0)",
