"use client";
/* eslint-disable @next/next/no-img-element */

import { useState } from "react";
import toast from "react-hot-toast";

const schedule = [
  { day: "Monday", topic: "AI Fundamentals & Prompt Engineering", time: "10:00 AM", instructor: "Mr. Chukwuemeka" },
  { day: "Tuesday", topic: "Frontend Development with React 19", time: "11:00 AM", instructor: "Mrs. Adaeze" },
  { day: "Wednesday", topic: "Backend APIs & Database Design", time: "10:00 AM", instructor: "Mr. Tunde" },
  { day: "Thursday", topic: "UI/UX Design Principles", time: "2:00 PM", instructor: "Miss. Ngozi" },
  { day: "Friday", topic: "Weekly Review & Project Sprint", time: "10:00 AM", instructor: "Mr. Chukwuemeka" },
];

const attendanceData = [
  { date: "Apr 1", present: true },
  { date: "Apr 2", present: true },
  { date: "Apr 3", present: false },
  { date: "Apr 4", present: true },
  { date: "Apr 5", present: true },
  { date: "Apr 6", present: true },
  { date: "Apr 7", present: true },
  { date: "Apr 8", present: false },
  { date: "Apr 9", present: true },
  { date: "Apr 10", present: true },
];

export default function ClassroomPage() {
  const [showFine, setShowFine] = useState(true);

  return (
    <div style={{ minHeight: "100vh", background: "#0A0E1A", color: "#E8EDF5", padding: "24px 32px" }}>
      <h1 style={{ fontSize: 24, fontWeight: 700, margin: "0 0 24px 0" }}>Classroom</h1>

      {/* Fine Alert Banner */}
      {showFine && (
        <div
          style={{
            background: "rgba(239,83,80,0.1)",
            border: "1px solid rgba(239,83,80,0.35)",
            borderRadius: 14,
            padding: 16,
            display: "flex",
            alignItems: "center",
            justifyContent: "space-between",
            marginBottom: 20,
          }}
        >
          <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
            <span style={{ fontSize: 20 }}>⚠️</span>
            <div>
              <p style={{ fontWeight: 600, color: "#EF5350", margin: 0, fontSize: 14 }}>
                Outstanding Fine: ₦2,500
              </p>
              <p style={{ fontSize: 13, color: "rgba(239,83,80,0.7)", margin: "4px 0 0 0" }}>
                Late submission penalty for Week 8 assignment. Please settle before April 15.
              </p>
            </div>
          </div>
          <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
            <button
              onClick={() => {
                const t = toast.loading("Processing payment...");
                setTimeout(() => {
                  toast.success("Fine paid successfully!", { id: t });
                  setShowFine(false);
                }, 1500);
              }}
              style={{
                background: "#EF5350",
                color: "#fff",
                border: "none",
                padding: "8px 18px",
                borderRadius: 8,
                fontSize: 13,
                fontWeight: 600,
                cursor: "pointer",
              }}
            >
              Pay
            </button>
            <button
              onClick={() => setShowFine(false)}
              style={{
                background: "none",
                border: "none",
                color: "#EF5350",
                fontSize: 20,
                cursor: "pointer",
                padding: 4,
              }}
            >
              ×
            </button>
          </div>
        </div>
      )}

      {/* LIVE NOW Card */}
      <div
        style={{
          background: "#111827",
          border: "1px solid rgba(255,193,7,0.3)",
          borderRadius: 16,
          padding: 24,
          position: "relative",
          overflow: "hidden",
          marginBottom: 20,
        }}
      >
        <div
          style={{
            position: "absolute",
            top: 0,
            right: 0,
            width: 160,
            height: 160,
            background: "rgba(30,136,229,0.08)",
            borderRadius: "50%",
            filter: "blur(40px)",
          }}
        />
        <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 10, position: "relative" }}>
          <span
            style={{
              width: 10,
              height: 10,
              borderRadius: "50%",
              background: "#EF5350",
              display: "inline-block",
              animation: "pulse 1.5s ease-in-out infinite",
            }}
          />
          <span style={{ color: "#EF5350", fontSize: 13, fontWeight: 600 }}>LIVE NOW</span>
        </div>
        <h2 style={{ fontSize: 20, fontWeight: 700, margin: "0 0 6px 0", position: "relative" }}>
          AI Fundamentals & Prompt Engineering
        </h2>
        <p style={{ color: "#8892A4", fontSize: 14, margin: "0 0 4px 0" }}>
          Instructor: Mr. Chukwuemeka
        </p>
        <div style={{ display: "flex", alignItems: "center", gap: 20, color: "#8892A4", fontSize: 13, margin: "0 0 16px 0" }}>
          <span>🕐 10:00 AM - 12:00 PM</span>
          <span>👥 24 attendees</span>
        </div>
        <button
          onClick={() => toast.success("Joining live class... 🎥")}
          style={{
            background: "#1E88E5",
            color: "#fff",
            border: "none",
            padding: "12px 24px",
            borderRadius: 12,
            fontSize: 14,
            fontWeight: 600,
            cursor: "pointer",
            display: "flex",
            alignItems: "center",
            gap: 8,
            boxShadow: "0 0 20px rgba(30,136,229,0.4)",
          }}
        >
          🎥 Join Live Class
        </button>
      </div>

      {/* Weekly Schedule */}
      <div
        style={{
          background: "#111827",
          borderRadius: 16,
          padding: 24,
          marginBottom: 20,
          border: "1px solid rgba(255,255,255,0.07)",
        }}
      >
        <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 16 }}>
          <span style={{ fontSize: 18 }}>📅</span>
          <h2 style={{ fontSize: 18, fontWeight: 700, margin: 0 }}>Weekly Schedule</h2>
        </div>
        <div style={{ overflowX: "auto" }}>
          <table style={{ width: "100%", fontSize: 14, borderCollapse: "collapse" }}>
            <thead>
              <tr style={{ color: "#8892A4", borderBottom: "1px solid rgba(255,255,255,0.07)" }}>
                <th style={{ textAlign: "left", padding: "12px 16px 12px 0", fontWeight: 500 }}>Day</th>
                <th style={{ textAlign: "left", padding: "12px 16px 12px 0", fontWeight: 500 }}>Topic</th>
                <th style={{ textAlign: "left", padding: "12px 16px 12px 0", fontWeight: 500 }}>Time</th>
                <th style={{ textAlign: "left", padding: "12px 0", fontWeight: 500 }}>Instructor</th>
              </tr>
            </thead>
            <tbody>
              {schedule.map((item, i) => (
                <tr
                  key={i}
                  style={{
                    borderBottom: i < schedule.length - 1 ? "1px solid rgba(255,255,255,0.04)" : "none",
                  }}
                >
                  <td style={{ padding: "12px 16px 12px 0", fontWeight: 600, color: "#1E88E5" }}>{item.day}</td>
                  <td style={{ padding: "12px 16px 12px 0", color: "#E8EDF5" }}>{item.topic}</td>
                  <td style={{ padding: "12px 16px 12px 0", color: "#8892A4" }}>{item.time}</td>
                  <td style={{ padding: "12px 0", color: "#8892A4" }}>{item.instructor}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Attendance Tracker */}
      <div
        style={{
          background: "#111827",
          borderRadius: 16,
          padding: 24,
          border: "1px solid rgba(255,255,255,0.07)",
        }}
      >
        <h2 style={{ fontSize: 18, fontWeight: 700, margin: "0 0 16px 0" }}>Attendance Tracker</h2>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(10, 1fr)", gap: 10 }}>
          {attendanceData.map((item, i) => (
            <div
              key={i}
              style={{
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
                padding: 12,
                borderRadius: 12,
                border: `1px solid ${item.present ? "rgba(102,187,106,0.3)" : "rgba(239,83,80,0.3)"}`,
                background: item.present ? "rgba(102,187,106,0.08)" : "rgba(239,83,80,0.08)",
              }}
            >
              <span style={{ fontSize: 18, color: item.present ? "#66BB6A" : "#EF5350" }}>
                {item.present ? "✓" : "✗"}
              </span>
              <span style={{ fontSize: 11, color: "#8892A4", marginTop: 4 }}>{item.date}</span>
            </div>
          ))}
        </div>
        <p style={{ fontSize: 14, color: "#8892A4", marginTop: 14 }}>
          Attendance:{" "}
          <span style={{ color: "#66BB6A", fontWeight: 600 }}>80%</span> (8/10 classes)
        </p>
      </div>

      {/* Pulse animation keyframes */}
      <style>{`
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.4; }
        }
      `}</style>
    </div>
  );
