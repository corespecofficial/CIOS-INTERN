  borderRadius: 6, padding: "3px 8px", fontSize: 10, fontWeight: 600, cursor: "pointer",
};
const navBtn: React.CSSProperties = {
  background: "rgba(255,255,255,0.05)", color: "#E8EDF5", border: "none",
  width: 28, height: 28, borderRadius: 8, fontSize: 16, cursor: "pointer",
};
const input: React.CSSProperties = {
  width: "100%", background: "#0A0E1A", border: "1px solid rgba(255,255,255,0.1)",
  borderRadius: 8, padding: "8px 10px", fontSize: 13, color: "#E8EDF5", outline: "none",
  fontFamily: "inherit",
